<?xml version="1.0" ?>
<!--*****************************************************-->
<!--**** Operation Durge's Lance: Killing Kaikielius ****-->
<!--*****************************************************-->

<Story>

	<Event Name="Battle_Start">
		<Event_Type>STORY_ELAPSED</Event_Type>
		<Event_Param1>0</Event_Param1>
	</Event>

	<Event Name="Disable_Retreat_PDF">
		<Event_Type>STORY_TRIGGER</Event_Type>
		<Reward_Type>DISABLE_RETREAT</Reward_Type>
		<Reward_Param1>SECTOR_FORCES</Reward_Param1>
		<Reward_Param2>1</Reward_Param2>
		<Prereq>Battle_Start</Prereq>
	</Event>

	<Event Name="CIS_Victory">
		<Event_Type>STORY_VICTORY</Event_Type>
		<Event_Param1>REBEL</Event_Param1>
	</Event>

	<Event Name="Rep_Victory">
		<Event_Type>STORY_VICTORY</Event_Type>
		<Event_Param1>EMPIRE</Event_Param1>
	</Event>

	<Event Name="Switch_Control_CIS">
		<Event_Type>STORY_AI_NOTIFICATION</Event_Type>
		<Event_Param2>ACTIVATE_CIS_AI</Event_Param2>
		<Reward_Type>SWITCH_CONTROL</Reward_Type>
		<Reward_Param1>Rebel</Reward_Param1>
		<Reward_Param2>CISMainAI</Reward_Param2>
		<Perpetual>True</Perpetual>
	</Event>

	<Event Name="Switch_Control_Rep">
		<Event_Type>STORY_AI_NOTIFICATION</Event_Type>
		<Event_Param2>ACTIVATE_REP_AI</Event_Param2>
		<Reward_Type>SWITCH_CONTROL</Reward_Type>
		<Reward_Param1>Empire</Reward_Param1>
		<Reward_Param2>RepublicAI</Reward_Param2>
		<Perpetual>True</Perpetual>
	</Event>

	<Event Name="Trigger_Grievous_Respawn">
		<Event_Type>STORY_TACTICAL_DESTROY</Event_Type>
		<Event_Param1>General_Grievous, Grievous_Recusant_Ground, Grievous_Malevolence_Ground, Grievous_Munificent_Ground, Grievous_Soulless_One_Ground</Event_Param1>
		<Event_Param3>1</Event_Param3>
		<Prereq>Battle_Start</Prereq>
	</Event>


	<Event Name="CIS_Goal_01">
		<Event_Type>STORY_TRIGGER</Event_Type>
		<Reward_Type>ADD_OBJECTIVE</Reward_Type>
		<Reward_Param1>TEXT_MISSION_KILLING_KAIKIELIUS_OBJECTIVE_CIS_01</Reward_Param1>
		<Prereq>Battle_Start</Prereq>
	</Event>

	<Event Name="CIS_Goal_01_Complete">
		<Event_Type>STORY_TRIGGER</Event_Type>
		<Reward_Type>OBJECTIVE_COMPLETE</Reward_Type>
		<Reward_Param1>TEXT_MISSION_ABREGADO_AMBUSH_OBJECTIVE_CIS_01</Reward_Param1>
		<Prereq>CIS_Goal_01, CIS_Victory</Prereq>
	</Event>

	<Event Name="CIS_Goal_01_Failed">
		<Event_Type>STORY_TRIGGER</Event_Type>
		<Reward_Type>OBJECTIVE_FAILED</Reward_Type>
		<Reward_Param1>TEXT_MISSION_ABREGADO_AMBUSH_OBJECTIVE_CIS_01</Reward_Param1>
		<Prereq>CIS_Goal_01, Rep_Victory</Prereq>
	</Event>

</Story>